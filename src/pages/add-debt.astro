---
import { supabase } from '../lib/supabase'
import { getSession } from '../lib/auth'
import BaseLayout from '../layouts/BaseLayout.astro'

const session = await getSession()

if (!session) {
  return Astro.redirect('/login')
}

let error = ''

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()

  const name = formData.get('name')?.toString() || ''
  const total_amount = Number(formData.get('total_amount'))

  const { error: insertError } = await supabase
    .from('debts')
    .insert({
      user_id: session.user.id,
      name,
      total_amount
    })

  if (insertError) {
    error = insertError.message
  } else {
    return Astro.redirect('/my-debts')
  }
}
---

<BaseLayout title="Add Debt">
  <div class="min-h-screen bg-gray-100 py-10">
    <div class="max-w-xl mx-auto bg-white p-6 rounded-xl shadow-md">

      <!-- Header -->
      <h1 class="text-2xl font-bold mb-6">Add Debt</h1>

      {error && (
        <p class="text-red-500 text-sm mb-4">{error}</p>
      )}

      <!-- Form -->
      <form method="POST" class="space-y-4">

        <div>
          <label class="block text-sm font-medium mb-1">
            Debt Name
          </label>
          <input
            name="name"
            placeholder="e.g. BDO Credit Card"
            required
            class="w-full border rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
          />
        </div>

        <div>
          <label class="block text-sm font-medium mb-1">
            Total Amount
          </label>
          <input
            name="total_amount"
            type="number"
            placeholder="Enter total amount"
            required
            class="w-full border rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
          />
        </div>

        <button
          class="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition"
        >
          Save Debt
        </button>
      </form>

      <!-- Back -->
      <div class="mt-6">
        <a
          href="/dashboard"
          class="text-blue-600 hover:underline text-sm"
        >
          ← Back to Dashboard
        </a>
      </div>

    </div>
  </div>
</BaseLayout>