---
import { supabase } from '../lib/supabase'
import { getSession } from '../lib/auth'
import BaseLayout from '../layouts/BaseLayout.astro'

const session = await getSession()
if (!session) return Astro.redirect('/login')

let error = ''

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()
  const total_amount = Number(formData.get('total_amount'))

  const { error: insertError } = await supabase
    .from('debts')
    .insert({
      user_id: session.user.id,
      name: 'Total Debt',
      total_amount
    })

  if (insertError) {
    error = insertError.message
  } else {
    return Astro.redirect('/dashboard')
  }
}
---

<BaseLayout title="Set Total Debt">
  <div class="min-h-screen flex items-center justify-center bg-gray-100 dark:bg-gray-950 px-4">

    <div class="w-full max-w-sm bg-white dark:bg-gray-900 p-6 rounded-xl shadow space-y-4">

      <h1 class="text-xl font-bold text-center">
        Set Your Total Debt
      </h1>

      <p class="text-sm text-gray-600 dark:text-gray-400 text-center">
        Enter your current debt amount to start tracking.
      </p>

      {error && (
        <p class="text-red-500 text-sm text-center">{error}</p>
      )}

      <form method="POST" class="space-y-4">

        <input
          name="total_amount"
          type="number"
          min="0"
          placeholder="Total debt amount"
          required
          class="w-full border dark:border-gray-700 dark:bg-gray-900 rounded-lg p-2"
        />

        <button
          class="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700"
        >
          Start Tracking
        </button>

      </form>

    </div>

  </div>
</BaseLayout>