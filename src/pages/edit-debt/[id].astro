---
import { supabase } from '../../lib/supabase'
import { getSession } from '../../lib/auth'
import BaseLayout from '../../layouts/BaseLayout.astro'

const session = await getSession()
if (!session) return Astro.redirect('/login')

const debtId = Astro.params.id

// Fetch current debt
const { data: debt } = await supabase
  .from('debts')
  .select('*')
  .eq('id', debtId)
  .eq('user_id', session.user.id)
  .single()

if (!debt) return Astro.redirect('/dashboard')

let error = ''

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()
  const total_amount = Number(formData.get('total_amount'))

  const { error: updateError } = await supabase
    .from('debts')
    .update({ total_amount })
    .eq('id', debtId)
    .eq('user_id', session.user.id)

  if (updateError) {
    error = updateError.message
  } else {
    return Astro.redirect('/dashboard')
  }
}
---

<BaseLayout title="Edit Total Debt">
  <div class="min-h-screen bg-gray-100 dark:bg-gray-950 flex flex-col justify-center px-4 pb-24">

    <div class="max-w-md mx-auto w-full space-y-6">

      <!-- Header -->
      <div>
        <h1 class="text-2xl font-bold">Edit Total Debt</h1>
        <p class="text-gray-600 dark:text-gray-400 mt-1">
          Update your total debt if new charges were added.
        </p>
      </div>

      <!-- Card -->
      <div class="bg-white dark:bg-gray-900 p-6 rounded-xl shadow space-y-4">

        {error && (
          <p class="text-red-500 text-sm">{error}</p>
        )}

        <form method="POST" class="space-y-4">

          <div>
            <label class="block text-sm font-medium mb-1">
              Total Debt Amount
            </label>

            <input
              name="total_amount"
              type="number"
              min="0"
              value={debt.total_amount}
              required
              class="w-full border dark:border-gray-700 dark:bg-gray-900 rounded-lg p-2 focus:ring-2 focus:ring-blue-500"
            />
          </div>

          <button
            class="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition"
          >
            Save Changes
          </button>

        </form>

      </div>

      <!-- Back -->
      <div>
        <a
          href="/dashboard"
          class="text-blue-600 hover:underline text-sm"
        >
          ← Back to Dashboard
        </a>
      </div>

    </div>

  </div>
</BaseLayout>