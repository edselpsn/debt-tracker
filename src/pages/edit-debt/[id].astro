---
import { supabase } from '../../lib/supabase'
import { getSession } from '../../lib/auth'
import BaseLayout from '../../layouts/BaseLayout.astro'

const session = await getSession()
if (!session) return Astro.redirect('/login')

const debtId = Astro.params.id

// Fetch current debt
const { data: debt } = await supabase
  .from('debts')
  .select('*')
  .eq('id', debtId)
  .eq('user_id', session.user.id)
  .single()

if (!debt) return Astro.redirect('/dashboard')

let error = ''

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()
  const total_amount = Number(formData.get('total_amount'))

  const { error: updateError } = await supabase
    .from('debts')
    .update({ total_amount })
    .eq('id', debtId)
    .eq('user_id', session.user.id)

  if (updateError) {
    error = updateError.message
  } else {
    return Astro.redirect('/dashboard')
  }
}
---

<BaseLayout title="Edit Total Debt">
  <div class="min-h-screen flex items-center justify-center bg-gray-100">
    <div class="w-full max-w-sm bg-white p-6 rounded-xl shadow-md">

      <h1 class="text-xl font-bold mb-4">Edit Total Debt</h1>

      <p class="text-sm text-gray-600 mb-4">
        Update your total debt if new charges were added.
      </p>

      {error && (
        <p class="text-red-500 text-sm mb-3">{error}</p>
      )}

      <form method="POST" class="space-y-4">

        <div>
          <label class="block text-sm font-medium mb-1">
            Total Debt Amount
          </label>
          <input
            name="total_amount"
            type="number"
            value={debt.total_amount}
            required
            class="w-full border rounded-lg p-2 focus:ring-2 focus:ring-blue-500"
          />
        </div>

        <button
          class="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition"
        >
          Save Changes
        </button>
      </form>

      <div class="mt-6">
        <a href="/dashboard" class="text-blue-600 hover:underline text-sm">
          ← Back to Dashboard
        </a>
      </div>

    </div>
  </div>
</BaseLayout>