---
import { supabase } from '../lib/supabase'
import { getSession } from '../lib/auth'
import BaseLayout from '../layouts/BaseLayout.astro'

const session = await getSession()
if (!session) return Astro.redirect('/login')

/* -------------------- MY DATA -------------------- */

const { data: debt } = await supabase
  .from('debts')
  .select('*')
  .eq('user_id', session.user.id)
  .single()

if (!debt?.id) return Astro.redirect('/set-debt')

const { data: payments } = await supabase
  .from('payments')
  .select('*')
  .eq('user_id', session.user.id)

const { data: profile } = await supabase
  .from('profiles')
  .select('name, invite_code')
  .eq('id', session.user.id)
  .single()

const myTotalDebt = Number(debt.total_amount || 0)
const myTotalPaid =
  payments?.reduce((sum, p) => sum + Number(p.amount), 0) || 0
const myRemaining = myTotalDebt - myTotalPaid
const myProgress =
  myTotalDebt > 0 ? (myTotalPaid / myTotalDebt) * 100 : 0

/* -------------------- COUPLE LOGIC -------------------- */

const { data: couple } = await supabase
  .from('couples')
  .select('*')
  .or(`user_one.eq.${session.user.id},user_two.eq.${session.user.id}`)
  .single()

let partnerId = null
let partnerProfile = null
let partnerDebt = null
let partnerPayments = []

if (couple) {
  partnerId =
    couple.user_one === session.user.id
      ? couple.user_two
      : couple.user_one

  const { data: pp } = await supabase
    .from('profiles')
    .select('name')
    .eq('id', partnerId)
    .single()

  partnerProfile = pp

  const { data: pd } = await supabase
    .from('debts')
    .select('*')
    .eq('user_id', partnerId)
    .single()

  partnerDebt = pd

  const { data: ppay } = await supabase
    .from('payments')
    .select('*')
    .eq('user_id', partnerId)

  partnerPayments = ppay || []
}

const partnerTotalDebt = Number(partnerDebt?.total_amount || 0)
const partnerTotalPaid =
  partnerPayments.reduce((sum, p) => sum + Number(p.amount), 0)
const partnerRemaining = partnerTotalDebt - partnerTotalPaid
const partnerProgress =
  partnerTotalDebt > 0
    ? (partnerTotalPaid / partnerTotalDebt) * 100
    : 0
---

<BaseLayout title="Dashboard" nav="dashboard">
  <div class="min-h-screen bg-gray-100 dark:bg-gray-950 py-12">
    <div class="max-w-md mx-auto px-4 py-8 pb-24 space-y-6">

      <!-- HEADER -->
      <div>
        <h1 class="text-3xl font-bold">Dashboard</h1>
        <p class="text-gray-600 dark:text-gray-400 mt-1">
          Welcome, <span class="font-medium">{profile?.name}</span>
        </p>
      </div>

      <!-- MY CARD -->
      <div class="bg-white dark:bg-gray-900 p-6 rounded-xl shadow space-y-4">
        <h2 class="font-semibold text-lg">Your Progress</h2>

        <div class="space-y-1 text-sm">
          <p><span class="font-medium">Total:</span> ₱{myTotalDebt.toLocaleString()}</p>
          <p><span class="font-medium">Paid:</span> ₱{myTotalPaid.toLocaleString()}</p>
          <p><span class="font-medium">Remaining:</span> ₱{myRemaining.toLocaleString()}</p>
        </div>

        <div>
          <div class="w-full bg-gray-200 dark:bg-gray-700 h-4 rounded-full">
            <div
              class="bg-green-500 h-4 rounded-full transition-all duration-500"
              style={`width: ${myProgress}%`}
            ></div>
          </div>

          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
            {myProgress.toFixed(1)}% paid
          </p>
        </div>

        <div class="flex gap-3 pt-2">
          <a
            href="/add-payment"
            class="flex-1 text-center bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition"
          >
            Add Payment
          </a>

          <a
            href={`/edit-debt/${debt.id}`}
            class="flex-1 text-center bg-gray-800 text-white py-2 rounded-lg hover:bg-gray-900 transition"
          >
            Edit Total
          </a>
        </div>
      </div>

      <!-- PARTNER -->
      {partnerId ? (
        <div class="bg-white dark:bg-gray-900 p-6 rounded-xl shadow space-y-4">
          <h2 class="font-semibold text-lg">
            {partnerProfile?.name}'s Progress
          </h2>

          <div class="space-y-1 text-sm">
            <p><span class="font-medium">Total:</span> ₱{partnerTotalDebt.toLocaleString()}</p>
            <p><span class="font-medium">Paid:</span> ₱{partnerTotalPaid.toLocaleString()}</p>
            <p><span class="font-medium">Remaining:</span> ₱{partnerRemaining.toLocaleString()}</p>
          </div>

          <div>
            <div class="w-full bg-gray-200 dark:bg-gray-700 h-4 rounded-full">
              <div
                class="bg-blue-500 h-4 rounded-full transition-all duration-500"
                style={`width: ${partnerProgress}%`}
              ></div>
            </div>

            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
              {partnerProgress.toFixed(1)}% paid
            </p>
          </div>
        </div>
      ) : (
        <div class="bg-white dark:bg-gray-900 p-6 rounded-xl shadow text-center space-y-5">
          <h2 class="font-semibold text-lg">Link a Partner</h2>

          <p class="text-sm text-gray-500 dark:text-gray-400">
            Share your invite code with your partner.
          </p>

          <div class="bg-gray-100 dark:bg-gray-800 rounded-lg py-3">
            <p class="text-xs text-gray-500 dark:text-gray-400">
              Your Invite Code
            </p>

            <p class="text-xl font-mono font-semibold tracking-widest">
              {profile?.invite_code}
            </p>
          </div>

          <a
            href="/link-partner"
            class="inline-block bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition"
          >
            Enter Partner Code
          </a>
        </div>
      )}

      <!-- LOGOUT -->
      <form method="POST" action="/logout">
        <button
          class="w-full bg-red-500 text-white py-2 rounded-lg hover:bg-red-600 transition"
        >
          Logout
        </button>
      </form>

    </div>
  </div>
</BaseLayout>